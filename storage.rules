rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isClubMember(clubId) {
      return isSignedIn() &&
        exists(/databases/(default)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    function isOwner(fileOwnerId) {
      return isSignedIn() && request.auth.uid == fileOwnerId;
    }

    // Club branding and media
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User avatars
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
